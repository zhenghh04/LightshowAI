# Copy to .env and fill in. Never commit .env.

# Required — Anthropic API key for the agent
ANTHROPIC_API_KEY=sk-ant-...

# Required — Materials Project API key (https://next-gen.materialsproject.org/api)
MP_API_KEY=...

# Recommended — shared password for collaborators (Deyu, Ozgur, ...).
# Leave blank to disable auth (any non-empty username is accepted).
CHAINLIT_PASSWORD=change-me-please

# Optional — model override. Defaults to claude-opus-4-7 if unset.
# Use claude-sonnet-4-6 if you want lower cost (~3x cheaper) at slightly
# weaker tool-use quality. Use claude-haiku-4-5 only for trivial demos.
# CLAUDE_MODEL=claude-opus-4-7
