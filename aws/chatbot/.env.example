# Copy to .env and fill in. Never commit .env.
#
# This config is tuned for the AmSC i2 LiteLLM gateway
# (https://api.i2-core.american-science-cloud.org/).
# Get a key from API Key Manager (top-right of the i2 console).

# --- i2 gateway auth -------------------------------------------------------
ANTHROPIC_AUTH_TOKEN=sk-...
ANTHROPIC_BASE_URL=https://api.i2-core.american-science-cloud.org

# --- model selection (AmSC convention; update when new models ship) --------
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
CLAUDE_CODE_SUBAGENT_MODEL=claude-haiku-4-5

# --- claude CLI behavior (recommended for proxy use) ----------------------
DISABLE_NON_ESSENTIAL_MODEL_CALLS=1
DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
CLAUDE_CODE_MAX_OUTPUT_TOKENS=8192
DISABLE_AUTOUPDATER=1

# --- Materials Project ----------------------------------------------------
MP_API_KEY=...

# --- AmSC MLflow tracking (via the bundled mlflow_server.py MCP) ----------
# AM_SC_API_KEY is the AmSC token used to authenticate against the MLflow
# tracking server. Often the same as your i2 API key — check with the AmSC team.
AM_SC_API_KEY=...
MLFLOW_TRACKING_URI=https://mlflow.american-science-cloud.org
# Keep TLS certificate verification enabled. Set to true only as a temporary
# workaround for a server/certificate-chain problem.
MLFLOW_TRACKING_INSECURE_TLS=false
# Keep MLflow from making the chat feel stuck if the tracking server is slow.
MLFLOW_HTTP_REQUEST_TIMEOUT=10
MLFLOW_HTTP_REQUEST_MAX_RETRIES=1

# --- Inline plot rendering ------------------------------------------------
# The browser fetches XANES plots and structure viewers from a separate static
# server (lightshowai-plots.service) on port 8001. Set this to the URL the
# browser should hit. On EC2 use the public IP; locally use localhost.
PLOTS_PUBLIC_URL=http://localhost:8001

# --- Chainlit shared-password auth ----------------------------------------
# Leave blank to disable auth (any non-empty username gets in).
CHAINLIT_PASSWORD=change-me-please
CHAINLIT_AUTH_SECRET=run-`python -c "import secrets;print(secrets.token_urlsafe(32))"`-once-and-paste
