# Copy to .env and fill in. Never commit .env.
#
# This config is tuned for the AmSC i2 LiteLLM gateway
# (https://api.i2-core.american-science-cloud.org/).
# Get a key from API Key Manager (top-right of the i2 console).

# --- i2 gateway auth -------------------------------------------------------
ANTHROPIC_AUTH_TOKEN=sk-...
ANTHROPIC_BASE_URL=https://api.i2-core.american-science-cloud.org

# --- model selection (AmSC convention; update when new models ship) --------
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
CLAUDE_CODE_SUBAGENT_MODEL=claude-haiku-4-5

# --- claude CLI behavior (recommended for proxy use) ----------------------
DISABLE_NON_ESSENTIAL_MODEL_CALLS=1
DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
CLAUDE_CODE_MAX_OUTPUT_TOKENS=8192
DISABLE_AUTOUPDATER=1

# --- Materials Project ----------------------------------------------------
MP_API_KEY=...

# --- Chainlit shared-password auth ----------------------------------------
# Leave blank to disable auth (any non-empty username gets in).
CHAINLIT_PASSWORD=change-me-please
