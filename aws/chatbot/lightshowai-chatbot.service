[Unit]
Description=LightshowAI XANES chatbot (Chainlit + Claude Agent SDK)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/LightshowAI/aws/chatbot
EnvironmentFile=/home/ubuntu/LightshowAI/aws/chatbot/.env
ExecStart=/home/ubuntu/venv-chatbot/bin/chainlit run app.py -h --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
# -h suppresses the auto-open-browser prompt.

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/ubuntu/LightshowAI /home/ubuntu/.chainlit /tmp
PrivateTmp=true

[Install]
WantedBy=multi-user.target
